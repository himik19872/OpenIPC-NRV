# NRV Backend — Environment Variables
# Скопируй этот файл в .env и заполни своими значениями

# Application
APP_NAME=NRV
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://nrv_user:nrv_password@localhost:5432/nrv_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Media Storage
MEDIA_ROOT=../media/recordings
MAX_RECORDING_DURATION_HOURS=24

# RTSP / WebRTC
GO2RTC_API_URL=http://localhost:1984/api

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2